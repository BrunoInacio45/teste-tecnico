# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly LF for files that must run on Linux
*.sh text eol=lf
Dockerfile text eol=lf
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
Makefile text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
